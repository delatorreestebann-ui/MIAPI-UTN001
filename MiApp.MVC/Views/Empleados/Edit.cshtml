@using MiApp.UTN.Modelos
@model Empleado

@{
    ViewData["Title"] = "Editar Empleado";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Empleado</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <input asp-for="Id" type="hidden" />


    <div class="mb-3">
        <label asp-for="Salario" class="form-label"></label>
        <input asp-for="Salario" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Salario" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Comisiono" class="form-label">Comisión</label>
        <input asp-for="Comisiono" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Comisiono" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FechaIngreso" class="form-label">Fecha de Ingreso</label>
        <input asp-for="FechaIngreso" class="form-control" type="date" />
        <span asp-validation-for="FechaIngreso" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PersonaId" class="form-label">ID Persona</label>
        <input asp-for="PersonaId" class="form-control" type="number" />
        <span asp-validation-for="PersonaId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CargoId" class="form-label">ID Cargo</label>
        <input asp-for="CargoId" class="form-control" type="number" />
        <span asp-validation-for="CargoId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
