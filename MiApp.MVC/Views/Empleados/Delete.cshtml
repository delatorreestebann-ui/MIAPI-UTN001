@using MiApp.UTN.Modelos
@model Empleado

@{
    ViewData["Title"] = "Eliminar Empleado";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Eliminar Empleado</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<p>¿ Está seguro que desea eliminar el siguiente registro ?</p>

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <td>@Model.Id</td>
    </tr>
    <tr>
        <th>Salario</th>
        <td>@Model.Salario</td>
    </tr>
    <tr>
        <th>Comisión</th>
        <td>@Model.Comisiono</td>
    </tr>
    <tr>
        <th>Fecha de Ingreso</th>
        <td>@Model.FechaIngreso.ToShortDateString()</td>
    </tr>
    <tr>
        <th>Persona ID</th>
        <td>@Model.PersonaId</td>
    </tr>
    <tr>
        <th>Cargo ID</th>
        <td>@Model.CargoId</td>
    </tr>
</table>

<form asp-action="Delete">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
</form>

<span> @ViewData["error"] </span>
